# Capacitor-generated native platforms — regenerated by cap add
# Leave commented out and COMMIT the android/ + ios/ dirs: they contain
# customizable native code (app icons, splash screens, signing config)
# that you don't want to lose on every rebuild.

node_modules/
package-lock.json

# Build artefacts
android/build/
android/app/build/
android/.gradle/
android/local.properties
android/.idea/
android/captures/

ios/App/Pods/
ios/App/build/
ios/App/DerivedData/
ios/.DS_Store

# www/ in bundle mode is generated from frontend/. In remote mode only
# the bootstrap splash lives here (keep committed so `cap sync` works
# out of the box on a fresh clone).
# www/
!www/index.html
