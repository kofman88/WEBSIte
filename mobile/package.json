{
  "name": "chm-finance-mobile",
  "version": "1.0.0",
  "description": "CHM Finance — Capacitor wrapper for iOS + Android (points at https://chmup.top)",
  "private": true,
  "scripts": {
    "init": "cap init 'CHM Finance' 'top.chmup.app' --web-dir=www",
    "add:android": "cap add android",
    "add:ios": "cap add ios",
    "sync": "cap sync",
    "open:android": "cap open android",
    "open:ios": "cap open ios",
    "run:android": "cap run android --list",
    "run:ios": "cap run ios --list",
    "build:www": "bash ../scripts/mobile-build-www.sh"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.1.0"
  },
  "dependencies": {
    "@capacitor/core": "^6.1.0",
    "@capacitor/android": "^6.1.0",
    "@capacitor/ios": "^6.1.0",
    "@capacitor/app": "^6.0.0",
    "@capacitor/browser": "^6.0.0",
    "@capacitor/network": "^6.0.0",
    "@capacitor/status-bar": "^6.0.0",
    "@capacitor/splash-screen": "^6.0.0",
    "@capacitor/push-notifications": "^6.0.0"
  }
}
