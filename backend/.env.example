# ══════════════════════════════════════════════════════════════════════════
# CHM Finance — backend environment
# Copy to `.env` and fill in for your environment.
# In production, all "CRITICAL" vars MUST be set or the server refuses to start.
# ══════════════════════════════════════════════════════════════════════════

# ── Runtime ───────────────────────────────────────────────────────────────
NODE_ENV=development           # development | production
PORT=3000
WS_PORT=3001
LOG_LEVEL=debug                # error | warn | info | debug

# ── CRITICAL: Authentication secrets ──────────────────────────────────────
# Generate each with: openssl rand -hex 32
# Must be at least 32 chars. In prod they MUST differ from each other.
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_TTL=1h
JWT_REFRESH_TTL=30d

# ── CRITICAL: Encryption key for API keys at rest ─────────────────────────
# AES-256-GCM requires 32 bytes = exactly 64 hex chars.
# Generate with: openssl rand -hex 32
# NEVER change this in production without re-encrypting all exchange_keys rows.
WALLET_ENCRYPTION_KEY=

# ── Database ──────────────────────────────────────────────────────────────
DATABASE_PATH=./data/chmup.db

# ── CORS ──────────────────────────────────────────────────────────────────
# Dev: use "*". Prod: lock to your domain (e.g. https://chmup.top)
CORS_ORIGIN=*

# ── Payments: Stripe (required in prod for fiat) ──────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLIC_KEY=

# ── Payments: Crypto (optional but recommended) ───────────────────────────
PAYMENT_BEP20_ADDRESS=
PAYMENT_TRC20_ADDRESS=
BSCSCAN_API_KEY=
TRONSCAN_API_KEY=

# ── Monitoring ────────────────────────────────────────────────────────────
SENTRY_DSN=

# ── Email (optional — for reset-password flows) ───────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ── Seed helper passwords (dev only) ──────────────────────────────────────
SEED_ADMIN_PASSWORD=admin123456
SEED_TEST_PASSWORD=test12345
