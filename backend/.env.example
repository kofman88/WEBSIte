# ── Server ────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Authentication ────────────────────────────────────────────────────────
# Replace with a strong random secret in production (e.g. openssl rand -hex 64)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# ── Database ──────────────────────────────────────────────────────────────
DATABASE_PATH=./data/chmup.db

# ── CORS ──────────────────────────────────────────────────────────────────
# In production, set this to your frontend domain (e.g. https://chmup.top)
CORS_ORIGIN=*

# ── Wallet Encryption ────────────────────────────────────────────────────
# MUST be exactly 32 bytes for AES-256-CBC. Generate with: openssl rand -hex 16
WALLET_ENCRYPTION_KEY=default-32-byte-key-change-prod!

# ── Payment / Stripe (optional) ──────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Exchange API keys (platform defaults, optional) ──────────────────────
# Users will typically provide their own keys via the UI.
BYBIT_API_KEY=
BYBIT_API_SECRET=
BINGX_API_KEY=
BINGX_API_SECRET=
BINANCE_API_KEY=
BINANCE_API_SECRET=
