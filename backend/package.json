  "devDependencies": {
    "@vitest/ui": "^2.1.0",
    "eslint": "^9.14.0",
    "eslint-plugin-security": "^3.0.1",
    "nodemon": "^3.1.7",
    "supertest": "^7.0.0",
    "vitest": "^2.1.0"
